{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:l2g:l2g_ssp_handoff_v1:1.0",
  "title": "L2G Workshop to SSP Handoff v1",
  "type": "object",
  "required": [
    "package_kind",
    "version",
    "package_id",
    "generated_at",
    "source_tool",
    "target_tool",
    "system",
    "catalog",
    "practices"
  ],
  "properties": {
    "package_kind": {
      "const": "l2g_ssp_handoff_v1"
    },
    "version": {
      "const": "1.0"
    },
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string"
    },
    "source_tool": {
      "type": "object",
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "target_tool": {
      "type": "object",
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "system": {
      "type": "object",
      "required": [
        "system_name"
      ],
      "properties": {
        "system_name": {
          "type": "string"
        },
        "system_id": {
          "type": "string"
        },
        "organization_name": {
          "type": "string"
        },
        "organization_id": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "catalog": {
      "type": "object",
      "required": [
        "framework",
        "level",
        "practice_count"
      ],
      "properties": {
        "framework": {
          "type": "string"
        },
        "level": {
          "type": "string"
        },
        "practice_count": {
          "const": 110
        }
      },
      "additionalProperties": true
    },
    "practices": {
      "type": "array",
      "minItems": 110,
      "maxItems": 110,
      "items": {
        "type": "object",
        "required": [
          "practice_id",
          "family",
          "title",
          "workshop_status",
          "workshop_notes",
          "evidence_references"
        ],
        "properties": {
          "practice_id": {
            "type": "string",
            "pattern": "^3\\.(?:[1-9]|1[0-4])\\.\\d+$"
          },
          "family": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "workshop_status": {
            "type": "string"
          },
          "workshop_notes": {
            "type": "string"
          },
          "evidence_references": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "interview_questions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "gaps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommended_actions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
