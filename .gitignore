# Local operating data and temporary exports
*.tmp
*.bak
*.log
.DS_Store
Thumbs.db

# Python / Node test caches
__pycache__/
*.pyc
.pytest_cache/
node_modules/

# Large generated release bundles and previews are attached to Releases/Actions by default
*.zip
*.7z
*.png
*.jpg
*.jpeg
*.xlsx
*.xlsm
*.docx
*.pptx
*.pdf

# Keep intentional small fixtures by force-adding when approved
!fixtures/**/README.md
